# ============================================================
# SERVER ENVIRONMENT VARIABLES — Copy to .env and fill in real values
# NEVER commit .env with real secrets!
# ============================================================

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT Secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_USE_64_CHAR_RANDOM_HEX_STRING
JWT_REFRESH_SECRET=CHANGE_ME_USE_64_CHAR_RANDOM_HEX_STRING


# Email credentials (Gmail App Password recommended)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Groq API Key (server-side only — NEVER put in client)
GROQ_API_KEY=gsk_your_groq_key_here

# Admin seed credentials
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Server port (optional, defaults to 5000)
PORT=5000
