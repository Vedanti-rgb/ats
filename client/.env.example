# ============================================================
# CLIENT ENVIRONMENT VARIABLES — Copy to .env.local and fill in values
# NEVER commit .env.local with real secrets!
# NOTE: All VITE_ variables are bundled into the browser — never put
#       secret API keys here. Only put PUBLIC keys (e.g., public analytics IDs).
# ============================================================

# API base URL pointing to the backend server
VITE_API_BASE_URL=http://localhost:5000
